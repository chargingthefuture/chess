{
  "name": "offline-chess-pwa",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "description": "Offline-first single-player chess PWA: play Stockfish at Easy/Medium/Hard, with an optional offline Coach and an optional online Explain (LLM) training feature.",
  "scripts": {
    "engine:copy": "node scripts/copy-engine.mjs",
    "predev": "node scripts/copy-engine.mjs",
    "dev": "vite",
    "prebuild": "node scripts/copy-engine.mjs",
    "build": "tsc -b && vite build",
    "preview": "vite preview"
  },
  "dependencies": {
    "chess.js": "^1.4.0",
    "react": "^19.2.7",
    "react-chessboard": "^5.10.0",
    "react-dom": "^19.2.7",
    "stockfish": "^18.0.8"
  },
  "devDependencies": {
    "@types/node": "^26.0.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "typescript": "^6.0.3",
    "vite": "^8.1.0",
    "vite-plugin-pwa": "^1.3.0"
  }
}
